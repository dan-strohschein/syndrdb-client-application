            "postprocess": null,
            "minimum-symbols": 1
            }
        ]
    },
    {
        "root": "field_assignment",
        "rules": [
            {"name": "field_assignment",
            "symbols": [
                {"reference": "field_reference", "optional": false},
                {"literal":"="},
