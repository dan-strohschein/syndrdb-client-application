                        [{"token":"NOT_EQ"}],
                        [{"token":"LT"}],
                        [{"token":"GT"}],
                        [{"token":"LT_EQ"}],
                        [{"token":"GT_EQ"}]
                    ]
                }
            ],
            "postprocess": null
            }
        ]
    },
    {
        "root": "condition_joiner",
        "rules": [
            {"name": "condition_joiner",
            "symbols": [
               {"branches": [
                    [{"token":"AND"}],
                    [{"token":"OR"}]
                ]}
            ],
            "minimum-symbols": 1,
            "postprocess": null
            }
        ]
    },
    {
        "root": "limit_clause",
        "rules": [
            {"name": "limit_clause",
            "symbols": [
                {"token":"LIMIT"},
                {"token": "literal", "optional": false}
            ],
