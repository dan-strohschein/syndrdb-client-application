                            {"literal":",", "optional": true},
                            {"reference": "select_item", "optional": true},
                            {"literal":",", "optional": true},
                            {"reference": "select_item", "optional": true},
                            {"literal":",", "optional": true},
                            {"reference": "select_item", "optional": true}
                        ],
                        [
                            {"token":"ASTERISK", "optional": false}
                        ],
                        [
                            {"literal":"documents", "optional": false}
                        ]
                    ]
                }

            ],
            "minimum-branches": 1,
            "postprocess": null
            }
        ]
    },
    {
        "root" : "select_item",
        "rules": [
            {"name": "select_item",
            "symbols": [
